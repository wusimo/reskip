{
  "attention_bias": false,
  "bos_token_id": 1,
  "eos_token_id": 2,
  "fuse_cross_entropy": true,
  "fuse_norm": true,
  "hidden_act": "swish",
  "hidden_size": 512,
  "initializer_range": 0.02,
  "max_position_embeddings": 8192,
  "model_type": "reloop_transformer",
  "num_heads": 16,
  "num_hidden_layers": 24,
  "norm_eps": 1e-06,
  "tie_word_embeddings": false,
  "use_cache": false,
  "vocab_size": 32000,
  "attn_res_num_blocks": 8,
  "attn_res_temperature": 1.0,
  "num_recurrent_blocks": 4,
  "max_loops": 2,
  "halt_threshold": 0.5,
  "halt_kl_weight": 0.01,
  "halt_kl_min_weight": 0.002,
  "halt_kl_decay_steps": 3000,
  "halt_use_phase1_stats": true,
  "halt_detach_phase1_stats": true,
  "halt_use_position_bias": true,
  "training_soft_min_halt": true,
  "halt_curriculum_disable_after_target": true,
  "halt_retain_target_after_curriculum": true,
  "early_exit_penalty_weight": 0.02,
  "early_exit_penalty_warmup_steps": 400,
  "focused_halt_loss_weight": 0.02,
  "focused_halt_loss_start_step": 600,
  "focused_halt_loss_warmup_steps": 400,
  "focused_halt_improvement_margin": 0.03,
  "focused_halt_target_temperature": 0.1,
  "ponder_loss_weight": 0.02,
  "ponder_loss_warmup_steps": 400,
  "ponder_budget_start_step": 500,
  "ponder_target_depth_ratio": 0.75,
  "ponder_target_steps": 3000
}
