{
  "attention_bias": false,
  "bos_token_id": 1,
  "eos_token_id": 2,
  "fuse_cross_entropy": true,
  "fuse_norm": true,
  "hidden_act": "swish",
  "hidden_size": 1024,
  "initializer_range": 0.02,
  "max_position_embeddings": 8192,
  "model_type": "reloop_transformer",
  "num_heads": 16,
  "num_hidden_layers": 24,
  "norm_eps": 1e-06,
  "tie_word_embeddings": false,
  "use_cache": false,
  "vocab_size": 32000,
  "attn_res_num_blocks": 8,
  "attn_res_temperature": 1.0,
  "num_recurrent_blocks": 4,
  "max_loops": 2,
  "halt_threshold": 0.5,
  "halt_kl_weight": 0.005,
  "halt_kl_min_weight": 0.001,
  "halt_kl_decay_steps": 300,
  "halt_use_phase1_stats": true,
  "halt_detach_phase1_stats": true,
  "training_soft_min_halt": true,
  "early_exit_penalty_weight": 0.02,
  "early_exit_penalty_warmup_steps": 40,
  "ponder_loss_weight": 0.02,
  "ponder_loss_warmup_steps": 50,
  "ponder_budget_start_step": 20,
  "ponder_target_depth_ratio": 0.75,
  "ponder_target_steps": 400
}
