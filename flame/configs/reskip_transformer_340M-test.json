  "use_cache": true,
  "vocab_size": 32000,
  "attn_res_num_blocks": 8,
  "attn_res_temperature": 1.0,
  "enable_looping": false,
  "num_recurrent_blocks": 8,
  "max_loops": 1,
  "enable_skip_inference": false,
  "skip_keep_mask": null,
  "halt_threshold": 0.99,
  "ponder_loss_weight": 0.0
